{
  "name": "n8n-nodes-upptime",
  "version": "0.1.9",
  "description": "n8n community node to fetch Upptime status monitoring data",
  "keywords": [
    "n8n-community-node-package",
    "upptime",
    "status",
    "monitoring"
  ],
  "license": "MIT",
  "author": {
    "name": "Ioannis Tavernarakis",
    "email": "ioannis@tavernarakis.eu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sakretsos/n8n-nodes-upptime.git"
  },
  "scripts": {
    "build": "n8n-node build && node -e \"const fs=require('fs'),path=require('path');fs.readdirSync('nodes',{recursive:true}).filter(f=>f.endsWith('.node.json')).forEach(f=>{const s=path.join('nodes',f),d=path.join('dist/nodes',f);fs.mkdirSync(path.dirname(d),{recursive:true});fs.copyFileSync(s,d)})\"",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "nodes": [
      "dist/nodes/Upptime/Upptime.node.js"
    ],
    "credentials": [
      "dist/credentials/UptimeApi.credentials.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "n8n-workflow": "*",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
